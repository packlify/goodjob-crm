# ===== GoodJob CRM 生产环境变量（Railway / Docker） =====
# 复制此文件为 .env.production 或直接填到 Railway 环境变量面板

# 端口（Railway 会自动注入 PORT，不需手动设）
PORT=4188

# 存储模式：mysql
CRM_STORE=mysql

# MySQL 连接（Railway 上 MySQL 插件会自动注入 DATABASE_URL）
# 如果不用 Railway MySQL 插件，手动填：
# DATABASE_URL=mysql://goodjob:your_password@host:3306/goodjob_crm
DATABASE_URL=mysql://goodjob:change_me@localhost:3306/goodjob_crm

# JWT 密钥（务必更换为强随机字符串！）
JWT_SECRET=replace_with_40_char_random_string

# 初始管理员（首次启动时自动创建，密码可后续登录后修改）
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=change_me_admin_123
INITIAL_ADMIN_NAME=Super Admin

# Session Cookie 安全（公网 HTTPS 部署请改为 true）
SESSION_COOKIE_SECURE=false

# CORS 允许的域名（生产环境设为你的前端域名，或用 * 测试）
CORS_ORIGINS=*

# API 文档（生产环境建议关闭）
ENABLE_API_DOCS=false
